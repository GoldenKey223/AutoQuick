{
  "version": 3,
  "configurePresets": [
    {
      "name": "msvc",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ]
}